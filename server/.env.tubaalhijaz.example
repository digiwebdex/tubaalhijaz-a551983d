# =====================================================
# Tuba Al Hijaz — Backend env (server/.env on the VPS)
# Copy to server/.env and fill in real values.
# =====================================================
NODE_ENV=production
PORT=4002

APP_NAME=Tuba Al Hijaz
APP_URL=https://tubaalhijaz.com
FRONTEND_URL=https://tubaalhijaz.com

# --- Database (self-hosted PostgreSQL on the VPS) ---
# Password MUST be URL-encoded (no @ : / # ? & in raw form).
DATABASE_URL=postgresql://tubaalhijaz_user:<URL_ENCODED_PASSWORD>@127.0.0.1:5432/tubaalhijaz_db

# --- Auth ---
JWT_SECRET=<CHANGE_ME_LONG_RANDOM>
JWT_REFRESH_SECRET=<CHANGE_ME_DIFFERENT_LONG_RANDOM>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Initial admin (created by seed; remove after first login)
ADMIN_EMAIL=admin@tubaalhijaz.com
ADMIN_PASSWORD=<CHANGE_ME_STRONG>

# --- Uploads & logs ---
UPLOAD_DIR=/var/www/tubaalhijaz/server/uploads
LOG_DIR=/var/www/tubaalhijaz/logs

# --- SMS (BulkSMS BD) — optional, leave blank to disable ---
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=TUBAHIJAZ

# --- Email (Resend) — optional ---
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@tubaalhijaz.com

# --- WhatsApp (used in frontend CTA) ---
WHATSAPP_NUMBER=

# --- SSLCommerz (online payments) — optional ---
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWORD=
SSLCZ_IS_LIVE=false

# --- Redis / BullMQ queues ---
# When set, message_queue rows are dispatched via BullMQ instead of the
# legacy in-process polling loop. Required for the tubaalhijaz-worker
# PM2 process. Leave blank to keep inline (no-Redis) fallback.
REDIS_URL=redis://127.0.0.1:6379

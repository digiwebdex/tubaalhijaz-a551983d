# =====================================================================
# Backend production environment template
# Copy to .env and replace every "REPLACE_ME" value before booting.
# Validate with:  node -e "require('./config/validateEnv')()"
# =====================================================================

# --- Runtime ---------------------------------------------------------
NODE_ENV=production
PORT=4002
APP_VERSION=1.0.0
FRONTEND_URL=https://tubaalhijaz.com

# --- Database --------------------------------------------------------
DATABASE_URL=postgresql://tubaalhijaz:REPLACE_ME@127.0.0.1:5433/tubaalhijaz

# --- Redis (queues + cache) -----------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# --- Auth / JWT ------------------------------------------------------
JWT_SECRET=REPLACE_ME_with_a_long_random_string
JWT_REFRESH_SECRET=REPLACE_ME_with_a_different_long_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- File uploads ----------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# --- Storage backend (local | s3 | r2 | spaces) ---------------------
STORAGE_DRIVER=local
# S3-compatible (only required when STORAGE_DRIVER != local)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- SMS (BulkSMS BD) -----------------------------------------------
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=

# --- Email (Resend) -------------------------------------------------
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@tubaalhijaz.com

# --- WhatsApp (optional) --------------------------------------------
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# --- Payments (SSLCommerz) ------------------------------------------
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true

# --- Observability --------------------------------------------------
LOG_LEVEL=info          # debug | info | warn | error
SLOW_QUERY_MS=500       # log queries slower than this
SENTRY_DSN=             # optional error aggregation

# /etc/nginx/sites-available/tubaalhijaz.com
# Symlink to /etc/nginx/sites-enabled/tubaalhijaz.com
# DO NOT touch any other site config on this VPS.

server {
    listen 80;
    listen [::]:80;
    server_name tubaalhijaz.com www.tubaalhijaz.com;

    # Certbot webroot (created by `mkdir -p /var/www/tubaalhijaz/.well-known`)
    location /.well-known/acme-challenge/ {
        root /var/www/tubaalhijaz;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tubaalhijaz.com www.tubaalhijaz.com;

    ssl_certificate     /etc/letsencrypt/live/tubaalhijaz.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tubaalhijaz.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 25M;
    access_log /var/www/tubaalhijaz/logs/nginx-access.log;
    error_log  /var/www/tubaalhijaz/logs/nginx-error.log;

    # Backend API
    location /api/ {
        proxy_pass http://127.0.0.1:4002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 120s;
    }

    # User uploads served directly
    location /uploads/ {
        alias /var/www/tubaalhijaz/server/uploads/;
        access_log off;
        expires 30d;
    }

    # SPA frontend
    location / {
        root /var/www/tubaalhijaz/dist;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Static asset caching
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff2?)$ {
        root /var/www/tubaalhijaz/dist;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }
}

# =====================================================
# Tuba Al Hijaz — Frontend build-time env (Vite)
# Copy to .env on the VPS BEFORE running `npm run build`.
# =====================================================
VITE_API_URL=/api

# These two are NOT used in production (the migrate.sh script
# rewrites src/integrations/supabase/client.ts to re-export the
# local API bridge). They exist only to silence the type stubs
# during build and can be left as harmless placeholders.
VITE_SUPABASE_URL=https://placeholder.invalid
VITE_SUPABASE_PUBLISHABLE_KEY=placeholder
VITE_SUPABASE_PROJECT_ID=placeholder
